# ============================================================================
# GRAVITY — environment variables
# Copy to `.env.local` and fill in real values. `.env.local` is gitignored.
# RULE: anything prefixed NEXT_PUBLIC_ is exposed to the browser. Secrets must
# NOT have that prefix and must only be read in server code.
# ============================================================================

# ─── App ───
NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── Phase 0: Supabase (DB / Auth / Storage / Realtime) ───
NEXT_PUBLIC_SUPABASE_URL=                # https://<project-ref>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=           # public anon key (RLS-limited; safe in browser)
SUPABASE_SERVICE_ROLE_KEY=               # SECRET — server only, NEVER ships to browser

# ─── Phase 0: Hidden super-admin gate ───
ADMIN_URL_SEGMENT=ctrl-change-me-to-random   # obscure URL segment for the admin area

# ─── Phase 0: Razorpay (payments) ───
RAZORPAY_KEY_ID=                         # test mode first: rzp_test_...
NEXT_PUBLIC_RAZORPAY_KEY_ID=             # same key id, needed by the browser checkout
RAZORPAY_KEY_SECRET=                     # SECRET — server only
RAZORPAY_WEBHOOK_SECRET=                 # SECRET — HMAC verification of webhooks

# ─── Phase 1/2: Email (Resend) ───
RESEND_API_KEY=                          # SECRET — room creds + notifications
RESEND_FROM_EMAIL=GRAVITY <noreply@yourdomain.com>

# ─── Phase 2: WhatsApp (room credential delivery) ───
# v1 uses free wa.me links (no key). Later, a provider:
WHATSAPP_PROVIDER_API_KEY=               # optional, SECRET
